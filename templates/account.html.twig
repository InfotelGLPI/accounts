{% import "components/form/fields_macros.html.twig" as fields %}

{% set bg = "" %}
{% if item.isDeleted() %}
    {% set bg = "asset-deleted" %}
{% endif %}

<div class="asset {{ bg }}">
    {% include("components/form/header.html.twig") %}

    {% set rand = random() %}
    {% set params  = params ?? [] %}
    {% set target       = params['target'] ?? item.getFormURL() %}
    {% set withtemplate = params['withtemplate'] ?? "" %}
    {% set item_type = item.getType() %}

    <div class="card-body d-flex">
        <div class="col-12 flex-column">
            <div class="d-flex flex-row flex-wrap flex-xl-nowrap">
                <div class="row flex-row align-items-start flex-grow-1">
                    <div class="row flex-row">

                        {#                        {% if item.isNewItem() and nbhashes == 0 %} #}
                        {#                            <div class='alert alert-warning d-flex'> #}
                        {#                                {{ __('WARNING : a encryption key already exist for this entity', 'accounts') }} #}
                        {#                            </div> #}
                        {#                        {% endif %} #}

                        {% if item.isField('name') %}
                            {{ fields.autoNameField(
                                "name",
                                item,
                                __('Name'),
                                withtemplate
                            ) }}
                        {% endif %}

                        {% if item.isField('plugin_accounts_accountstates_id') %}
                            {{ fields.dropdownField(
                                "GlpiPlugin\\Accounts\\AccountState",
                                "plugin_accounts_accountstates_id",
                                item.fields['plugin_accounts_accountstates_id'],
                                __("Status"),
                                {
                                    'entity': item.fields['entities_id'],
                                }
                            ) }}
                        {% endif %}

                        {% if item.isField('login') %}
                            {{ fields.textField(
                                "login",
                                item.fields['login'],
                                __("Login"),
                            ) }}
                        {% endif %}


                        {% if item.isField('plugin_accounts_accounttypes_id') %}
                            {{ fields.dropdownField(
                                "GlpiPlugin\\Accounts\\AccountType",
                                "plugin_accounts_accounttypes_id",
                                item.fields['plugin_accounts_accounttypes_id'],
                                __("Type"),
                                {
                                    'entity': item.fields['entities_id'],
                                }
                            ) }}
                        {% endif %}

                        {% if get_current_interface() == 'central' %}

                            {% if item.isNewItem() %}
                                {{ fields.dropdownField(
                                    'GlpiPlugin\\Accounts\\Hash',
                                    'plugin_accounts_hashes_id',
                                    item.fields["plugin_accounts_hashes_id"],
                                    'GlpiPlugin\\Accounts\\Hash'|itemtype_name,
                                    {'entity' : item.getEntityID(),
                                        'rand' : rand,
                                        'required': true,
                                        'on_change': 'checkInputIfNewEncryptionKey(this.value, ' ~ item.fields['plugin_accounts_hashes_id'] ~ ')'}
                                ) }}

                                {% do call('Ajax::updateItemOnSelectEvent', [
                                    'dropdown_plugin_accounts_hashes_id' ~ rand,
                                    'change_good_hash',
                                    config('root_doc') ~ '/plugins/accounts/ajax/getHashOnSelectEncryptionKey.php',
                                    {
                                        'plugin_accounts_hashes_id': '__VALUE__',
                                    }
                                ]) %}
                            {% endif %}

                            {% if not (item.isNewItem()) and canupdateHash == true %}
                                {{ fields.dropdownField(
                                    'GlpiPlugin\\Accounts\\Hash',
                                    'plugin_accounts_hashes_id',
                                    item.fields["plugin_accounts_hashes_id"],
                                    'GlpiPlugin\\Accounts\\Hash'|itemtype_name,
                                    {'entity' : item.getEntityID(),
                                        'rand' : rand,
                                        'required': true,
                                        'on_change': 'checkInputIfNewEncryptionKey(this.value, ' ~ item.fields['plugin_accounts_hashes_id'] ~ ')'}
                                ) }}

                                {% do call('Ajax::updateItemOnSelectEvent', [
                                    'dropdown_plugin_accounts_hashes_id' ~ rand,
                                    'change_good_hash',
                                    config('root_doc') ~ '/plugins/accounts/ajax/getHashOnSelectEncryptionKey.php',
                                    {
                                        'plugin_accounts_hashes_id': '__VALUE__',
                                    }
                                ]) %}
                            {% else %}
                                <div class="form-field row align-items-center col-12 col-sm-6 mb-2">
                                    <label class="col-form-label col-xxl-5 text-xxl-end ">
                                        {{ _n('Fingerprint', 'Fingerprints', 1,'accounts') }}
                                    </label>
                                    <div class="col-xxl-7 field-container">
                                    <span class="default_encryption_key">
                                    {{ call('Dropdown::getDropdownName', ["glpi_plugin_accounts_hashes", item.fields['plugin_accounts_hashes_id']]) }}
                                    </span>
                                    </div>
                                </div>
                            {% endif %}

                            <div class="form-field row align-items-center col-12 col-sm-6 mb-2">
                                <label class="col-form-label col-xxl-5 text-xxl-end">
                                </label>
                                <div class="col-xxl-7 field-container">
                                </div>
                            </div>

                        {% else %}

                            <div class="form-field row align-items-center col-12 col-sm-6 mb-2">
                                <label class="col-form-label col-xxl-5 text-xxl-end ">
                                    {{ _n('Fingerprint', 'Fingerprints', 1,'accounts') }}
                                </label>
                                <div class="col-xxl-7 field-container">
                                    <span class="default_encryption_key">
                                    {{ call('Dropdown::getDropdownName', ["glpi_plugin_accounts_hashes", item.fields['plugin_accounts_hashes_id']]) }}
                                    </span>
                                </div>
                            </div>
                            <div class="form-field row align-items-center col-12 col-sm-6 mb-2">
                                <label class="col-form-label col-xxl-5 text-xxl-end">
                                </label>
                                <div class="col-xxl-7 field-container">
                                </div>
                            </div>

                        {% endif %}
                        <div id="alertfootprint" class="alert alert-warning">
                            {{ __('WARNING: If you change the associated fingerprint, you will no longer be able to correctly decrypt the password. You will also need to update the password.', 'accounts') }}
                        </div>
                        <input type="hidden" id="change_good_hash"/>
                        {% if aeskey_uncrypted is not defined or aeskey_uncrypted == false %}
                            <div class="form-field row align-items-center col-12 col-sm-6 mb-2">
                                <label class="col-form-label col-xxl-5 text-xxl-end">
                                    {{ __('Encryption key', 'accounts') }}
                                </label>
                                <div class="col-xxl-7 field-container">
                                    <div class="btn-group btn-group-sm d-flex">
                                        <input type="password" name="aeskey" id="aeskey" size="30" autocomplete="off"/>
                                        <input type="hidden" name="good_hash" id="good_hash" size="40"
                                               autocomplete="off"
                                               value="{{ hash }}"/>
                                        <input type="hidden" name="encrypted_password" id="encrypted_password" size="40"
                                               autocomplete="off"
                                               value="{{ item.fields['encrypted_password'] }}"/>
                                        <div class="btn btn-outline-secondary btn-light"
                                             onclick="uncryptpassword()">
                                            <i class="ti ti-lock-open"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="form-field row align-items-center col-12 col-sm-6 mb-2">
                                <label class="col-form-label col-xxl-5 text-xxl-end">
                                    {{ __('Password') }}
                                </label>
                                <div class="col-xxl-7 field-container">
                                    <input type="hidden" name="wrong_key_locale" id="wrong_key_locale" size="40"
                                           autocomplete="off"
                                           value="{{ __('Wrong encryption key', 'accounts') }}"/>
                                    <div id="wrong_key_locale_div" style="color:red"></div>
                                    <div class="btn-group btn-group-sm d-flex">
                                        <input type="password" id="hidden_password" class="form-control "
                                               name="hidden_password"
                                               size='30'>

                                        <div class="btn btn-outline-secondary btn-light"
                                             onmousedown="showDisclosablePasswordField('hidden_password')"
                                             onmouseup="hideDisclosablePasswordField('hidden_password')"
                                             onmouseout="hideDisclosablePasswordField('hidden_password')">
                                            <i class="ti ti-eye disclose"></i>
                                        </div>

                                        <div class="btn btn-outline-secondary btn-light"
                                             onclick="copyDisclosablePasswordFieldToClipboard('hidden_password')">
                                            <i class="ti ti-clipboard-copy disclose"></i>
                                        </div>

                                    </div>
                                    {% if get_current_interface() == 'central' %}
                                        <span class="d-inline-flex">
                                        <input type="checkbox" name="_blank_account_passwd" id="__blank_account_passwd"
                                               class="ms-1">
                                        <label for="__blank_account_passwd" class="ms-1">
                                            {{ __('Clear') }}
                                        </label>
                                    </span>
                                    {% endif %}
                                </div>
                            </div>

                        {% else %}
                            <div class="form-field row align-items-center col-12 col-sm-6 mb-2">
                                <label class="col-form-label col-xxl-5 text-xxl-end">
                                    {{ __('Encryption key', 'accounts') }}
                                </label>
                                <div class="col-xxl-7 field-container">
                                    <div class="btn-group btn-group-sm d-flex">
                                        <input type="password" name="aeskey" id="aeskey" size="40"
                                               autocomplete="off"
                                               value="{{ aeskey_uncrypted }}"/>
                                        <input type="hidden" name="good_hash" id="good_hash" size="40"
                                               autocomplete="off"
                                               value="{{ hash }}"/>
                                        <input type="hidden" name="encrypted_password" id="encrypted_password" size="40"
                                               autocomplete="off"
                                               value="{{ item.fields['encrypted_password'] }}"/>
                                        <script type="text/javascript">
                                            $(document).ready(function () {
                                                auto_decrypt();
                                            });
                                        </script>
                                    </div>
                                </div>
                            </div>
                            <div class="form-field row align-items-center col-12 col-sm-6 mb-2">
                                <label class="col-form-label col-xxl-5 text-xxl-end">
                                    {{ __('Password') }}
                                </label>
                                <div class="col-xxl-7 field-container">
                                    <input type="hidden" name="wrong_key_locale" id="wrong_key_locale" size="40"
                                           autocomplete="off"
                                           value="{{ __('Wrong encryption key', 'accounts') }}"/>
                                    <div id="wrong_key_locale_div" style="color:red"></div>
                                    <div class="btn-group btn-group-sm d-flex">
                                        <input type="password" id="hidden_password" class="form-control "
                                               name="hidden_password"
                                               size='30'>

                                        <div class="btn btn-outline-secondary"
                                             onmousedown="showDisclosablePasswordField('hidden_password')"
                                             onmouseup="hideDisclosablePasswordField('hidden_password')"
                                             onmouseout="hideDisclosablePasswordField('hidden_password')">
                                            <i class="ti ti-eye disclose"></i>
                                        </div>

                                        <div class="btn btn-outline-secondary"
                                             onclick="copyDisclosablePasswordFieldToClipboard('hidden_password')">
                                            <i class="ti ti-clipboard-copy disclose"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}

                        {% if item.isField('users_id') %}
                            {% if get_current_interface() == 'central' %}
                                {{ fields.dropdownField(
                                    "User",
                                    "users_id",
                                    item.fields['users_id'],
                                    __('Affected User', 'accounts'),
                                    {
                                        'entity': item.fields['entities_id'],
                                        'right': 'all',
                                    }
                                ) }}
                            {% else %}
                                <div class="form-field row align-items-center col-12 col-sm-6 mb-2">
                                    <label class="col-form-label col-xxl-5 text-xxl-end">
                                        {{ __('Affected User', 'accounts') }}
                                    </label>
                                    <div class="col-xxl-7 field-container">
                                        {{ call('getUserName', [item.fields['users_id']]) }}
                                    </div>
                                </div>
                            {% endif %}
                        {% endif %}


                        {% if item.isField('groups_id') %}
                            {% if get_current_interface() == 'central' %}

                                {{ fields.dropdownField(
                                    'Group',
                                    'groups_id',
                                    item.fields['groups_id'],
                                    __('Affected Group', 'accounts'),
                                    {
                                        'entity': item.fields['entities_id'],
                                        'condition': {'is_itemgroup': 1},
                                        'multiple': false,
                                    }
                                ) }}
                            {% else %}
                                <div class="form-field row align-items-center col-12 col-sm-6 mb-2">
                                    <label class="col-form-label col-xxl-5 text-xxl-end">
                                        {{ __('Affected Group', 'accounts') }}
                                    </label>
                                    <div class="col-xxl-7 field-container">
                                        {{ call('Dropdown::getDropdownName', ["glpi_groups", item.fields['groups_id']]) }}
                                    </div>
                                </div>
                            {% endif %}
                        {% endif %}

                        {% set current_day = time|date('Y-m-d') %}
                        {% if item.isField('date_creation') %}
                            {{ fields.dateField('date_creation',
                                item.fields['date_creation']|default(current_day),
                                __('Creation date'), {
                                }) }}
                        {% endif %}


                        {% if item.isField('users_id_tech') %}
                            {% if get_current_interface() == 'central' %}
                                {{ fields.dropdownField(
                                    "User",
                                    "users_id_tech",
                                    item.fields['users_id_tech'],
                                    __('Technician in charge'),
                                    {
                                        'entity': item.fields['entities_id'],
                                        'right': 'interface',
                                    }
                                ) }}
                            {% else %}
                                <div class="form-field row align-items-center col-12 col-sm-6 mb-2">
                                    <label class="col-form-label col-xxl-5 text-xxl-end">
                                        {{ __('Technician in charge') }}
                                    </label>
                                    <div class="col-xxl-7 field-container">
                                        {{ call('getUserName', [item.fields['users_id_tech']]) }}
                                    </div>
                                </div>
                            {% endif %}
                        {% endif %}

                        {% if item.isField('date_expiration') %}
                            {{ fields.dateField('date_expiration',
                                item.fields['date_expiration'],
                                __('Expiration date'), {
                                    'helper': __('Empty for infinite')
                                }) }}
                        {% endif %}

                        {% if item.isField('groups_id_tech') %}
                            {% if get_current_interface() == 'central' %}

                                {{ fields.dropdownField(
                                    'Group',
                                    'groups_id_tech',
                                    item.fields['groups_id_tech'],
                                    __('Group in charge'),
                                    {
                                        'entity': item.fields['entities_id'],
                                        'condition': {'is_assign': 1},
                                        'multiple': false,
                                    }
                                ) }}
                            {% else %}
                                <div class="form-field row align-items-center col-12 col-sm-6 mb-2">
                                    <label class="col-form-label col-xxl-5 text-xxl-end">
                                        {{ __('Group in charge') }}
                                    </label>
                                    <div class="col-xxl-7 field-container">
                                        {{ call('Dropdown::getDropdownName', ["glpi_groups", item.fields['groups_id_tech']]) }}
                                    </div>
                                </div>
                            {% endif %}
                        {% endif %}


                        {% if item.isField('others') %}
                            {{ fields.textField(
                                "others",
                                item.fields['others'],
                                __('Others'),
                            ) }}
                        {% endif %}

                        {% if item.isField('locations_id') %}
                            {{ fields.dropdownField(
                                "Location",
                                "locations_id",
                                item.fields['locations_id'],
                                "Location"|itemtype_name,
                                {
                                    'entity': item.fields['entities_id'],
                                }
                            ) }}
                        {% endif %}

                        {% if item.isField('comment') %}
                            {{ fields.textareaField(
                                "comment",
                                item.fields['comment'],
                                _n('Comment', 'Comments', 2),
                            ) }}
                        {% endif %}

                        {% if item.isField('is_helpdesk_visible') %}
                            {{ fields.checkboxField(
                                'is_helpdesk_visible',
                                item.fields['is_helpdesk_visible'],
                                __('Associable to a ticket')
                            ) }}
                        {% endif %}


                    </div> {# .row #}
                </div> {# .row #}
            </div> {# .flex-row #}
        </div>

    </div> {# .card-body #}
    {% if item.isNewItem() %}
        <script type="text/javascript">
            $('#account_form').submit(function (event) {
                let hiddenPassword = $('input[name="hidden_password"]').val();
                let aeskey = $('input[name="aeskey"]').val();
                if (hiddenPassword == '' || aeskey == '') {
                    alert('{{ __('You have not filled the password and encryption key', 'accounts') }}');
                    return false;
                }
                if (!check_hash()) {
                    alert('{{ __('Wrong encryption key', 'accounts') }}');
                    return false;
                } else {
                    encrypt_password();
                }
            });
        </script>
    {% else %}
        <script type="text/javascript">
            $('#account_form').submit(function (event) {
                let hiddenPassword = $('input[name="hidden_password"]').val();
                let aeskey = $('input[name="aeskey"]').val();
                if ((hiddenPassword == '' || aeskey == '')) {
                    alert('{{ __('Password will not be modified', 'accounts') }}');
                } else if (!check_hash()) {
                    alert('{{ __('Wrong encryption key', 'accounts') }}');
                    return false;
                } else {
                    encrypt_password();
                }
            });
        </script>
    {% endif %}
    {% include("components/form/buttons.html.twig") %}
    {#    {% include("components/form/inventory_info.html.twig") %} #}


    {% if params['formfooter'] == null %}
        <div class="card-footer mx-n2 mb-n2 mt-4">
            {% include("components/form/dates.html.twig") %}
        </div>
    {% endif %}
</div>

<script type="text/javascript">
    $(document).on('click', '#generate_hash', function (event) {
        if ($('input[name="aeskey"]').val() == '' || $('input[name="aeskey"]').val() == undefined) {
            alert('{{ __('Please fill the encryption key', 'accounts') }}');
            $('input[name="hash"]').val('');
        } else {
            $('input[name="hash"]').val(SHA256(SHA256($('input[name="aeskey"]').val())));
        }
    });

</script>


{# Password Generator — Bootstrap 5 card, shown for both new and existing items #}
{% if show_password_generator %}
    <div class="row flex-row mt-3">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="ti ti-key me-1"></i>
                        {{ __('Generate password', 'accounts') }}
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-2 align-items-center">
                        {# Character set checkboxes #}
                        <div class="col-12 col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" checked id="char-0">
                                <label class="form-check-label" for="char-0">
                                    {{ __('Numbers', 'accounts') }}
                                    <small class="text-muted">(0123456789)</small>
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" checked id="char-1">
                                <label class="form-check-label" for="char-1">
                                    {{ __('Lowercase', 'accounts') }}
                                    <small class="text-muted">(abcdefghijklmnopqrstuvwxyz)</small>
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" checked id="char-2">
                                <label class="form-check-label" for="char-2">
                                    {{ __('Uppercase', 'accounts') }}
                                    <small class="text-muted">(ABCDEFGHIJKLMNOPQRSTUVWXYZ)</small>
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="char-3">
                                <label class="form-check-label" for="char-3">
                                    {{ __('Special characters', 'accounts') }}
                                    <small class="text-muted">(!\"#$%&amp;'()*+,-./:;&lt;=&gt;?@[\]^_`{|}~)</small>
                                </label>
                            </div>
                        </div>

                        {# Length + Generate button #}
                        <div class="col-12 col-md-6">
                            <div class="input-group mb-2" style="max-width: 220px;">
                                <label class="input-group-text" for="length">
                                    {{ __('Length', 'accounts') }}
                                </label>
                                <input type="number" min="1" max="512" value="16" step="1"
                                       id="length" class="form-control" style="max-width: 80px;">
                                <span class="input-group-text">
                    {{ __('characters', 'accounts') }}
                    </span>
                            </div>
                            <div id="fakeupdate"></div>
                            <button type="button"
                                    id="generatePass"
                                    name="generatePass"
                                    class="btn btn-primary">
                                <i class="ti ti-refresh me-1"></i>
                                {{ __('Generate', 'accounts') }}
                            </button>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>


    {# Wire up the AJAX event (keep existing behaviour) #}
    {% do call('Ajax::updateItemOnEvent', [
        'generatePass',
        'fakeupdate',
        root_accounts_doc ~ '/ajax/generatepassword.php',
        {'password': 1},
        ['click']
    ]) %}
{% endif %}
